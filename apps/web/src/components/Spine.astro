---
import type { Book, BuiltWaypoint } from '@rtp/schema';
import Stop from './Stop.astro';
import { isSimultaneous, milesApart } from '../lib/books';

interface Props {
  book: Book;
  slug: string;
  group: BuiltWaypoint[];
  /** True for the first stop group, whose plate is the LCP element. */
  first?: boolean;
}

const { book, slug, group, first = false } = Astro.props;

const paired = isSimultaneous(group);
const head = group[0]!;
const apart = paired && group[1] ? milesApart(head.coords, group[1].coords) : null;
---

<section class="hour" data-paired={paired ? '' : undefined}>
  <div class="strike">
    <span class="label">{head.progressLabel}</span>
    <span class="pct">{Math.round(head.position * 100)}% in</span>
  </div>

  {
    paired && (
      <p class="fork-lede">
        One sentence. One stroke of the clock. <strong>Two places, {apart} apart.</strong> The
        characters never meet.
      </p>
    )
  }

  <div class={paired ? 'fork' : undefined}>
    {group.map((wp, i) => <Stop book={book} slug={slug} wp={wp} eager={first && i === 0} />)}
  </div>
</section>
