---
import '../styles/tokens.css';

interface Props {
  title: string;
  description: string;
  /** The book's accent, which is a quotation from the book's own text. */
  accent?: string;
  ogImage?: string;
  /** Open Graph type: "website" for the home page, "article" for book/city pages. */
  ogType?: string;
  /** schema.org JSON-LD. We only assert what the build has verified. */
  schema?: unknown[];
  /** The LCP image, preloaded so its fetch starts with the HTML. */
  preloadImage?: string;
}

const {
  title,
  description,
  accent,
  ogImage,
  ogType = 'article',
  schema = [],
  preloadImage,
} = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
const og = ogImage ? new URL(ogImage, Astro.site) : undefined;
const repo = 'https://github.com/markselby9/readtheplaces.com';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <meta property="og:site_name" content="Read the Places" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    {og && <meta property="og:image" content={og} />}
    <meta name="twitter:card" content={og ? 'summary_large_image' : 'summary'} />

    {
      schema.map((s) => (
        <script is:inline type="application/ld+json" set:html={JSON.stringify(s)} />
      ))
    }

    {preloadImage && <link rel="preload" href={preloadImage} as="image" fetchpriority="high" />}

    <link
      rel="preload"
      href="/fonts/literata-normal.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/atkinson-normal.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
  </head>

  <body style={accent ? `--accent: ${accent}` : undefined}>
    <a class="skip" href="#main">Skip to content</a>

    <header class="site-nav">
      <div class="wrap">
        <a class="brand" href="/">Read the Places</a>
        <form class="nav-search" role="search" action="/" method="get">
          <input
            id="book-search"
            name="q"
            type="search"
            aria-label="Search books by title, author, or city"
            placeholder="Search books…"
            autocomplete="off"
            spellcheck="false"
            aria-describedby="search-count"
            enterkeyhint="search"
          />
          <span id="search-count" class="search-count" role="status" aria-live="polite"></span>
        </form>
        <nav aria-label="Primary">
          <a href="/#mapped">Books</a>
          <a href="/browse/">Browse</a>
          <a href="/contribute/">Add a book</a>
        </nav>
      </div>
    </header>

    <slot />

    <footer class="site-foot">
      <div class="wrap foot-grid">
        <div class="foot-about">
          <p class="foot-brand">Read the Places</p>
          <p>An open atlas of the real places in novels, in the order the story happens.</p>
        </div>

        <nav class="foot-col" aria-label="Explore">
          <h2>Explore</h2>
          <ul>
            <li><a href="/#mapped">All books</a></li>
            <li><a href="/browse/">Browse by country, author, era</a></li>
            <li><a href="/#by-city">By city</a></li>
            <li><a href="/#open">Open for adoption</a></li>
          </ul>
        </nav>

        <nav class="foot-col" aria-label="Contribute">
          <h2>Contribute</h2>
          <ul>
            <li><a href="/contribute/">Add a book</a></li>
            <li><a href={repo}>Source on GitHub</a></li>
            <li><a href={`${repo}/issues`}>Open issues</a></li>
          </ul>
        </nav>

        <div class="foot-col foot-legal">
          <h2>Credits</h2>
          <p>
            Book data <a href={`${repo}/blob/main/LICENSE`}>CC BY-SA 4.0</a>. Code MIT.
          </p>
          <p>
            Maps © <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors.
            Historical maps © <a href="https://maps.nls.uk/">National Library of Scotland</a>.
          </p>
        </div>
      </div>
    </footer>
  </body>
</html>
