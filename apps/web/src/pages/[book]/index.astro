---
import Base from '../../layouts/Base.astro';
import Spine from '../../components/Spine.astro';
import Adopt from '../../components/Adopt.astro';
import { accentOf, allBooks, isStub, loadBook, stopGroups } from '../../lib/books';
import { bookSchema, breadcrumbSchema } from '../../lib/structured-data';
import { slugifyCity } from '../places/[city].astro';
import { wikivoyageUrl } from '@rtp/schema';

export async function getStaticPaths() {
  const books = await allBooks();
  return books.map(({ slug }) => ({ params: { book: slug } }));
}

const slug = Astro.params.book!;
const loaded = await loadBook(slug);
const { book, waypoints } = loaded;

const stub = isStub(loaded);
const groups = stopGroups(waypoints);
const historical = book.layers?.historical;

const citySlug = slugifyCity(book.setting.city);

const repo = 'https://github.com/markselby9/readtheplaces.com';
// Keep the curated issue templates (they are the contribution model); only the
// title is pre-filled, so the book is identified without overriding the body.
const correctionUrl = `${repo}/issues/new?template=bug.md&title=${encodeURIComponent(`Correction: ${book.title}`)}`;
const addPlaceUrl = `${repo}/issues/new?template=add-a-place.md&title=${encodeURIComponent(`Waypoint: <place>, ${book.title}`)}`;

const title = `The ${book.setting.city} of ${book.title}`;
const description = stub
  ? `${book.title} by ${book.author}, set in ${book.setting.city}. Listed and open for adoption: nobody has mapped its places yet.`
  : `${waypoints.length} real places from ${book.title}, in the order ${book.author} visits them.`;
const schema = [
  bookSchema(loaded),
  breadcrumbSchema([
    { name: 'Read the Places', url: '/' },
    { name: book.setting.city, url: `/places/${citySlug}/` },
    { name: book.title, url: `/${slug}/` },
  ]),
];
---

<Base
  title={title}
  description={description}
  accent={accentOf(book)}
  ogImage={`/og/${slug}.png`}
  schema={schema}
  preloadImage={stub ? undefined : `/plates/${slug}/${waypoints[0]!.id}-now.webp`}
>
  <div class="wrap">
    <nav class="crumbs" aria-label="Breadcrumb">
      <a href="/">Read the Places</a>
      <span aria-hidden="true">/</span>
      <a href={`/places/${citySlug}/`}>{book.setting.city}</a>
      <span aria-hidden="true">/</span>
      <span>{book.title}</span>
    </nav>

    <header class="mast">
      <h1>The {book.setting.city} of <em>{book.title}</em></h1>
      <p class="standfirst">{book.setting.note}</p>

      <dl class="colophon">
        <div>
          <dt>Author</dt>
          <dd>{book.author}, {book.published}</dd>
        </div>
        <div>
          <dt>Places</dt>
          <dd>{stub ? 'none yet' : waypoints.length}</dd>
        </div>
        {
          historical && (
            <div>
              <dt>Historical map</dt>
              <dd>{historical.name}</dd>
            </div>
          )
        }
        {
          book.palette?.accentSourceQuote && (
            <div>
              <dt>Accent colour</dt>
              <dd>“{book.palette.accentSourceQuote}”</dd>
            </div>
          )
        }
      </dl>

      {
        (!stub || book.setting.wikivoyage) && (
          <p class="actions">
            {!stub && <a href={`/${slug}/read/`}>Open the interactive map →</a>}
            {book.setting.wikivoyage && (
              <a
                href={wikivoyageUrl(book.setting.wikivoyage)}
                target="_blank"
                rel="noopener noreferrer"
              >
                Visit {book.setting.city} on Wikivoyage ↗
              </a>
            )}
          </p>
        )
      }
    </header>
  </div>

  {
    stub ? (
      <main id="main" class="wrap">
        <Adopt slug={slug} book={book} />
      </main>
    ) : (
      <main id="main" class="wrap timeline" data-ordering={book.orderingKey}>
        {groups.map((group, i) => (
          <Spine book={book} slug={slug} group={group} first={i === 0} />
        ))}
      </main>
    )
  }

  {
    !stub && (
      <aside class="wrap correction">
        <p>
          Read this book and know it better than we do?{' '}
          <a href={addPlaceUrl}>Add a missing place →</a> or{' '}
          <a href={correctionUrl}>suggest a correction →</a>. Both open a pre-filled GitHub issue;
          no code required.
        </p>
      </aside>
    )
  }
</Base>

<style>
  .correction {
    padding-block: var(--s6) var(--s8);
    font-family: var(--sans);
    font-size: var(--step--1);
    color: var(--ink-3);
  }
  .correction a {
    text-decoration: none;
    border-bottom: 1px solid var(--accent-soft);
    padding-bottom: 2px;
    white-space: nowrap;
  }
  .correction a:hover {
    border-bottom-color: var(--accent);
  }
</style>
