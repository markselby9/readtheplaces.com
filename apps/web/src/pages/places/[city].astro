---
import Base from '../../layouts/Base.astro';
import { accentOf, allBooks, isStub, type LoadedBook } from '../../lib/books';
import { breadcrumbSchema, citySchema } from '../../lib/structured-data';

/**
 * A hub page per city.
 *
 * Six novels are set in London and four in Paris. Somebody searching for
 * "literary places in London" wants all six, not one, and there was nowhere on
 * the site that answered that. These pages are the answer, and they also give
 * the book pages something to be linked from, which is the whole reason internal
 * linking exists.
 */

export function slugifyCity(city: string): string {
  return city
    .toLowerCase()
    .normalize('NFD')
    .replace(/[̀-ͯ]/g, '')
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/^-|-$/g, '');
}

export async function getStaticPaths() {
  const books = await allBooks();

  const byCity = new Map<string, LoadedBook[]>();
  for (const b of books) {
    const key = b.book.setting.city;
    byCity.set(key, [...(byCity.get(key) ?? []), b]);
  }

  return [...byCity.entries()].map(([city, list]) => ({
    params: { city: slugifyCity(city) },
    props: { city, books: list },
  }));
}

const { city, books } = Astro.props as { city: string; books: LoadedBook[] };

const country = books[0]!.book.setting.country;
const mapped = books.filter((b) => !isStub(b));
const open = books.filter(isStub);
const places = mapped.reduce((n, b) => n + b.waypoints.length, 0);

const title = `Literary places in ${city}: ${books.length} novel${books.length === 1 ? '' : 's'} mapped`;
const description =
  mapped.length > 0
    ? `${places} real places from ${mapped.length} novel${mapped.length === 1 ? '' : 's'} set in ${city}, each anchored to a verbatim line from the book and mapped in the order the story visits it.`
    : `${books.length} novel${books.length === 1 ? '' : 's'} set in ${city}, listed and waiting for someone to map their places.`;

const schema = [
  citySchema(city, country, books),
  breadcrumbSchema([
    { name: 'Read the Places', url: '/' },
    { name: city, url: `/places/${slugifyCity(city)}/` },
  ]),
];
---

<Base title={title} description={description} schema={schema}>
  <div class="wrap">
    <nav class="crumbs" aria-label="Breadcrumb">
      <a href="/">Read the Places</a>
      <span aria-hidden="true">/</span>
      <span>{city}</span>
    </nav>

    <header class="mast">
      <p class="kicker">{books.length} novel{books.length === 1 ? '' : 's'}</p>
      <h1>Literary places in <em>{city}</em></h1>
      <p class="standfirst">
        {
          mapped.length > 0
            ? `${places} places from ${city}, taken from the novels that put them there. Every one is anchored to a verbatim line from the text.`
            : `These novels are set in ${city}. Nobody has mapped their places yet.`
        }
      </p>
    </header>

    <main id="main">
      {
        mapped.length > 0 && (
          <section aria-labelledby="mapped">
            <h2 id="mapped" class="section">
              Mapped
            </h2>
            <ul class="books">
              {mapped.map(({ slug, book, waypoints }) => (
                <li style={`--accent: ${accentOf(book)}`}>
                  <a href={`/${slug}/`}>
                    <span class="meta">{book.published}</span>
                    <h3>{book.title}</h3>
                    <p class="by">{book.author}</p>
                    <p class="note">{book.setting.note}</p>
                    <p class="count">{waypoints.length} places →</p>
                  </a>
                </li>
              ))}
            </ul>
          </section>
        )
      }

      {
        open.length > 0 && (
          <section aria-labelledby="open">
            <h2 id="open" class="section">
              Open for adoption
            </h2>
            <ul class="books stubs">
              {open.map(({ slug, book }) => (
                <li>
                  <a href={`/${slug}/`}>
                    <span class="meta">{book.published}</span>
                    <h3>{book.title}</h3>
                    <p class="by">{book.author}</p>
                    <p class="count claim">Adopt this book →</p>
                  </a>
                </li>
              ))}
            </ul>
          </section>
        )
      }
    </main>
  </div>
</Base>

<style>
  .crumbs {
    padding-top: var(--s6);
    font-family: var(--sans);
    font-size: var(--step--1);
    color: var(--ink-3);
  }
  .crumbs a {
    color: var(--ink-2);
  }
  .crumbs span[aria-hidden] {
    margin-inline: 0.4rem;
  }

  .mast {
    padding-block: var(--s6) var(--s7);
  }

  .section {
    margin-block: var(--s7) var(--s4);
    font-size: var(--step-2);
    font-weight: 400;
  }

  .books {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(17rem, 1fr));
    gap: var(--s4);
    padding: 0;
    margin-bottom: var(--s8);
  }
  .books a {
    display: block;
    height: 100%;
    padding: var(--s5);
    background: var(--paper-2);
    border: 1px solid var(--rule);
    border-left: 3px solid var(--accent);
    color: inherit;
    text-decoration: none;
    transition: border-color 0.2s var(--ease);
  }
  .books a:hover {
    border-color: var(--accent);
  }
  .books .meta,
  .books .by,
  .books .count {
    font-family: var(--sans);
    font-size: var(--step--1);
    color: var(--ink-3);
  }
  .books .meta {
    font-size: 0.62rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .books h3 {
    margin-block: var(--s2) var(--s1);
    font-size: var(--step-1);
    font-weight: 400;
    font-style: italic;
    line-height: 1.2;
  }
  .books .note {
    margin-block: var(--s3);
    color: var(--ink-2);
    font-size: var(--step--1);
    line-height: 1.55;
  }
  .books .count {
    margin-top: var(--s3);
    color: var(--accent);
    font-weight: 700;
  }

  .stubs a {
    border-style: dashed;
    border-left-color: var(--ink-3);
    background: transparent;
  }
  .stubs .claim {
    color: var(--ink-2);
  }
</style>
