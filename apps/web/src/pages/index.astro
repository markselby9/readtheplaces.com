---
import Base from '../layouts/Base.astro';
import { accentOf, allBooks, isStub } from '../lib/books';
import { websiteSchema } from '../lib/structured-data';
import { slugifyCity } from './places/[city].astro';
import popularity from '../data/popularity.json';

const books = await allBooks();

const pop = popularity as Record<string, { article: string; views: number }>;
const viewsOf = (slug: string) => pop[slug]?.views ?? 0;

// Default order is "most read on Wikipedia", a stand-in for fame. The sort
// control re-orders client-side; this is what someone without JS sees.
const mapped = books.filter((b) => !isStub(b)).sort((a, b) => viewsOf(b.slug) - viewsOf(a.slug));
const open = books.filter(isStub);

const cities = [...new Set(mapped.map((b) => b.book.setting.city))];
const places = mapped.reduce((n, b) => n + b.waypoints.length, 0);

const cityLinks = [...new Set(mapped.map((b) => b.book.setting.city))].sort();
const schema = [websiteSchema(mapped.length, cities.length)];
---

<Base
  title="Read the Places — A Literary Atlas of Real Places"
  description={`Explore the real places in ${mapped.length} books, mapped in the order each story visits them — across ${cities.length} cities, every location tied to a line from the text.`}
  ogImage="/og/mrs-dalloway.png"
  ogType="website"
  schema={schema}
>
  <div class="wrap">
    <header class="mast">
      <h1>Not a map of books.<br /><em>A book you can walk through.</em></h1>
      <p class="standfirst">
        An open atlas of the real places in novels, in the order the story visits them. Every place
        is pinned to a verbatim line from the book, and says how sure we are that it is the right
        place.
      </p>

      <dl class="colophon">
        <div>
          <dt>Books</dt>
          <dd>{mapped.length}</dd>
        </div>
        <div>
          <dt>Cities</dt>
          <dd>{cities.length}</dd>
        </div>
        <div>
          <dt>Places mapped</dt>
          <dd>{places}</dd>
        </div>
        <div>
          <dt>Open for adoption</dt>
          <dd>{open.length}</dd>
        </div>
      </dl>
    </header>

    <main id="main">
      <p class="no-results" hidden>
        Nothing matches that. Try a city or an author, or <a href="#open">browse the open list</a>.
      </p>

      <section aria-labelledby="mapped" data-search-section>
        <div class="section-head">
          <h2 id="mapped" class="section">Mapped</h2>
          <div class="sortbar">
            <label for="sort">Sort</label>
            <select id="sort">
              <option value="popularity">Most read on Wikipedia</option>
              <option value="places">Most places mapped</option>
              <option value="newest">Newest</option>
              <option value="oldest">Oldest</option>
              <option value="title">A–Z</option>
            </select>
          </div>
        </div>
        <ul class="books">
          {
            mapped.map(({ slug, book, waypoints }) => (
              <li
                style={`--accent: ${accentOf(book)}`}
                data-search={`${book.title} ${book.author} ${book.setting.city} ${book.setting.country}`.toLowerCase()}
                data-popularity={viewsOf(slug)}
                data-places={waypoints.length}
                data-year={book.published ?? 0}
                data-title={book.title.toLowerCase()}
              >
                <a href={`/${slug}/`}>
                  <span class="meta">
                    {book.setting.city} · {book.published}
                  </span>
                  <h3>{book.title}</h3>
                  <p class="by">{book.author}</p>
                  <p class="note">{book.setting.note}</p>
                  <p class="count">{waypoints.length} places →</p>
                </a>
              </li>
            ))
          }
        </ul>
      </section>

      <nav class="cities" aria-label="Browse by city" id="by-city" data-search-section>
        <h2 class="section">By city</h2>
        <ul>
          {
            cityLinks.map((c) => (
              <li data-search={c.toLowerCase()}>
                <a href={`/places/${slugifyCity(c)}/`}>{c}</a>
              </li>
            ))
          }
        </ul>
        <p class="browse-more">
          Or <a href="/browse/">browse by country, author or era →</a>
        </p>
      </nav>

      <section class="pitch" aria-labelledby="why">
        <h2 id="why">Why the order matters</h2>
        <p>
          A map with a chapter filter is a map of pins, and those already exist. What they cannot do
          is this. In <em>Mrs Dalloway</em>, at noon:
        </p>
        <blockquote>
          …twelve o’clock struck as Clarissa Dalloway laid her green dress on her bed, <strong
            >and the Warren Smiths walked down Harley Street.</strong
          >
        </blockquote>
        <p>
          One sentence. One stroke of the clock. Two places nearly two miles apart, two people who
          never meet, one of whom will be dead within six hours. Order is the whole difference.
        </p>
      </section>

      <section aria-labelledby="open" data-search-section>
        <h2 id="open" class="section">Open for adoption</h2>
        <p class="section-note">
          Listed because they can be done: the text is public domain, the city is real, and the
          places in them are findable. Each is waiting for somebody who has read it. <a
            href="/contribute/">You do not need to write code.</a
          >
        </p>

        <ul class="books stubs">
          {
            open.map(({ slug, book }) => (
              <li
                data-search={`${book.title} ${book.author} ${book.setting.city} ${book.setting.country}`.toLowerCase()}
              >
                <a href={`/${slug}/`}>
                  <span class="meta">
                    {book.setting.city} · {book.published}
                  </span>
                  <h3>{book.title}</h3>
                  <p class="by">{book.author}</p>
                  <p class="count claim">Adopt this book →</p>
                </a>
              </li>
            ))
          }
        </ul>
      </section>
    </main>
  </div>
</Base>

<script>
  // Progressive enhancement: without this, the page is the full list. With it,
  // the nav box narrows the grids and the city list live. No framework, no
  // request. The input lives in the site nav (see Base.astro), so it also shows
  // on other pages; there it just GET-submits to /?q=… and this page applies it.
  const input = document.getElementById('book-search') as HTMLInputElement | null;
  const sections = [...document.querySelectorAll<HTMLElement>('[data-search-section]')];
  const mappedGrid = document.querySelector<HTMLElement>(
    'section[aria-labelledby="mapped"] .books',
  );

  // Show a first screenful, not 300 cards. The rest is one click (or a search)
  // away. The whole list stays in the DOM, so search reaches every book and the
  // no-JS page is still the full catalogue; JS just caps what is on screen.
  const PAGE = window.matchMedia('(max-width: 40rem)').matches ? 12 : 24;
  let shown = PAGE;
  let refresh: () => void = () => {};

  if (input && sections.length && mappedGrid) {
    const count = document.getElementById('search-count')!;
    const empty = document.querySelector<HTMLElement>('.no-results')!;
    const items = [...document.querySelectorAll<HTMLElement>('[data-search]')];
    const bookCount = mappedGrid.querySelectorAll('[data-search]').length;

    const more = document.createElement('button');
    more.type = 'button';
    more.className = 'show-more';
    mappedGrid.after(more);
    more.addEventListener('click', () => {
      const first = shown;
      shown += PAGE;
      refresh();
      // Send focus to the first newly revealed card, so keyboard users continue
      // where the list grew rather than jumping back to the top.
      (mappedGrid.children[first] as HTMLElement | undefined)?.querySelector('a')?.focus();
    });

    refresh = () => {
      const q = input.value.trim().toLowerCase();
      const searching = q.length > 0;
      document.body.classList.toggle('is-searching', searching);

      // City links and stub cards: filtered by search only, never capped.
      for (const el of items) {
        if (mappedGrid.contains(el)) continue;
        el.hidden = searching && !el.dataset.search!.includes(q);
      }

      // Mapped grid: every match when searching, else just the first `shown`.
      const cards = [...mappedGrid.children] as HTMLElement[];
      cards.forEach((el, i) => {
        const matched = !searching || el.dataset.search!.includes(q);
        el.hidden = searching ? !matched : i >= shown;
      });
      const remaining = cards.length - shown;
      more.hidden = searching || remaining <= 0;
      more.textContent = `Show more — ${remaining} of ${cards.length} not shown`;

      for (const s of sections) {
        s.hidden = searching && !s.querySelector('[data-search]:not([hidden])');
      }
      const shownBooks = mappedGrid.querySelectorAll('[data-search]:not([hidden])').length;
      const shownCities = document.querySelectorAll('.cities [data-search]:not([hidden])').length;
      empty.hidden = !searching || shownBooks + shownCities > 0;
      count.textContent = searching ? `${shownBooks} of ${bookCount} books` : '';
    };

    // Carry a query in from another page's nav search (/?q=…).
    const initial = new URLSearchParams(location.search).get('q');
    if (initial) input.value = initial;

    // Here the box filters live, so Enter should not reload the page.
    input.form?.addEventListener('submit', (e) => e.preventDefault());
    input.addEventListener('input', refresh);
    refresh();
  }

  // Re-sort the mapped grid. Server-renders "most read"; this lets the reader
  // pick another order without a request, then re-applies the cap so the new
  // order's first cards are the ones on screen.
  const sortSel = document.getElementById('sort') as HTMLSelectElement | null;
  if (sortSel && mappedGrid) {
    const num = (li: HTMLElement, k: string) => Number(li.dataset[k] ?? 0);
    sortSel.addEventListener('change', () => {
      const cards = [...mappedGrid.children] as HTMLElement[];
      const k = sortSel.value;
      cards.sort((a, b) => {
        if (k === 'title') return a.dataset.title!.localeCompare(b.dataset.title!);
        if (k === 'oldest') return num(a, 'year') - num(b, 'year');
        if (k === 'newest') return num(b, 'year') - num(a, 'year');
        if (k === 'places') return num(b, 'places') - num(a, 'places');
        return num(b, 'popularity') - num(a, 'popularity');
      });
      for (const li of cards) mappedGrid.appendChild(li);
      refresh();
    });
  }
</script>

<style>
  .no-results {
    margin-top: var(--s6);
    font-family: var(--sans);
    color: var(--ink-2);
  }
  /* While searching, the prose sections are noise. */
  :global(body.is-searching) .pitch,
  :global(body.is-searching) .section-note {
    display: none;
  }

  .section {
    margin-block: var(--s8) var(--s4);
    font-size: var(--step-2);
    font-weight: 400;
  }
  .section-head {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--s2) var(--s4);
  }
  .sortbar {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    font-family: var(--sans);
    font-size: var(--step--1);
    color: var(--ink-3);
  }
  .sortbar select {
    font-family: var(--sans);
    font-size: var(--step--1);
    color: var(--ink);
    background: var(--paper-2);
    border: 1px solid var(--rule);
    border-radius: 2px;
    padding: 0.25rem 0.5rem;
  }
  /* No point offering a sort while a search has narrowed the grid. */
  :global(body.is-searching) .sortbar {
    display: none;
  }
  .section-note {
    max-width: 40rem;
    margin-bottom: var(--s5);
    color: var(--ink-2);
    font-size: var(--step--1);
    font-family: var(--sans);
    line-height: 1.65;
  }

  .books {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(17rem, 1fr));
    gap: var(--s4);
    padding: 0;
  }
  /* Full DOM stays (crawlable, client-filterable), but offscreen cards are
     skipped during layout/paint — a large win on long lists and low-end phones. */
  .books > li {
    content-visibility: auto;
    contain-intrinsic-size: auto 15rem;
  }
  .books a {
    display: block;
    height: 100%;
    padding: var(--s5);
    background: var(--paper-2);
    border: 1px solid var(--rule);
    border-left: 3px solid var(--accent);
    color: inherit;
    text-decoration: none;
    transition: border-color 0.2s var(--ease);
  }
  .books a:hover {
    border-color: var(--accent);
  }
  .books .meta,
  .books .by,
  .books .count {
    font-family: var(--sans);
    font-size: var(--step--1);
    color: var(--ink-3);
  }
  .books .meta {
    font-size: 0.62rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .books h3 {
    margin-block: var(--s2) var(--s1);
    font-size: var(--step-1);
    font-weight: 400;
    font-style: italic;
    line-height: 1.2;
  }
  .books .note {
    margin-block: var(--s3);
    color: var(--ink-2);
    font-size: var(--step--1);
    line-height: 1.55;
    /* Keep browse cards uniform and scannable; the full note is on the book page. */
    display: -webkit-box;
    -webkit-line-clamp: 3;
    line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .books .count {
    margin-top: var(--s3);
    color: var(--accent);
    font-weight: 700;
  }

  .show-more {
    display: block;
    width: 100%;
    margin-top: var(--s4);
    padding: var(--s3);
    font-family: var(--sans);
    font-size: var(--step--1);
    color: var(--ink-2);
    background: var(--paper-2);
    border: 1px solid var(--rule);
    border-radius: 2px;
    cursor: pointer;
    transition:
      border-color 0.2s var(--ease),
      color 0.2s var(--ease);
  }
  .show-more:hover {
    border-color: var(--accent);
    color: var(--ink);
  }

  /* A stub looks provisional on purpose: dashed, uncoloured, waiting. */
  .stubs a {
    border-style: dashed;
    border-left-color: var(--ink-3);
    background: transparent;
  }
  .stubs a:hover {
    border-color: var(--ink);
  }
  .stubs .claim {
    color: var(--ink-2);
  }

  .cities ul {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: var(--s2) var(--s4);
    padding: 0;
  }
  .cities a {
    display: inline-block;
    font-family: var(--sans);
    font-size: var(--step--1);
    color: var(--ink-2);
    text-decoration: none;
    border-bottom: 1px solid var(--rule);
    /* Roomier tap target for a dense tag list on touch screens. */
    padding: 6px 0;
  }
  .cities a:hover {
    border-bottom-color: var(--accent);
    color: var(--ink);
  }
  .browse-more {
    margin-top: var(--s4);
    font-family: var(--sans);
    font-size: var(--step--1);
    color: var(--ink-2);
  }

  .pitch {
    max-width: 38rem;
    margin-block: var(--s9);
  }
  .pitch h2 {
    margin-bottom: var(--s4);
    font-size: var(--step-2);
    font-weight: 400;
  }
  .pitch p {
    margin-bottom: var(--s4);
    color: var(--ink-2);
  }
  .pitch blockquote {
    color: var(--ink);
  }
</style>
